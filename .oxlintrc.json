{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "import", "unicorn"],
    "rules": {
        "sort-imports": [
            "error",
            {
                "ignoreCase": false,
                "ignoreDeclarationSort": false,
                "ignoreMemberSort": false
            }
        ]
    }
}
